	    },

    "tray": {
    "icon-size": 21,
    "spacing": 10,
    "icons": {
        "blueman": "bluetooth",
        "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
     }
    },

    "pulseaudio": {
		"format": "{icon}  {volume}",
		"on-click": "omarchy-launch-audio",
		"on-click-right": "omarchy-launch-audio",
		"tooltip-format": "Playing at {volume}%",
		"scroll-step": 5,
		"format-muted": "Ό╗ρ  {volume}",
		"format-icons": {
			"default": [
				"ΎΑο",
				"ΎΑπ ",
				"ΎΑρ "
			]
		}
    },

    "network": {
		"format-icons": ["≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"],
		"format": "{icon} {essid}",
		"format-wifi": "{icon}  {essid}",
		"format-ethernet": "≤░Να eth2ernet",
		"format-disconnected": "≤░νχ",
		"tooltip-format-wifi": "{essid} ({frequency} GHz)\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
		"tooltip-format-ethernet": "έΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
		"tooltip-format-disconnected": "Disconnected",
		"interval": 3,
		"spacing": 1,
		"on-click": "omarchy-launch-wifi"
    },

