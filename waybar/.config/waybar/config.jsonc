{
    "position": "top",
    "margin-top": 12,
    "modules-left": ["clock", "hyprland/language", "mpris"],
    "modules-center": [ "hyprland/workspaces", "custom/notification"],
    "modules-right":[
        "tray",
        "pulseaudio",
        "network",
		"bluetooth",
		"battery",
    ],


    //MODULES//
	"bluetooth": {
		"format": "َ°‚¯  {num_connections}",
		"format-disabled": "َ°‚²",
		"format-connected": "َ°‚± {num_connections}",
		"tooltip-format": "{num_connections} connected\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}",
		"on-click": "omarchy-launch-bluetooth"
	},

	// For laptops
	"battery": {
		"format": "{capacity}",
		"format-charging": "{icon}  {capacity}",
		"format-plugged": "{icon}  {capacity}",
		"format-full": "{icon}  100%",
		"format-icons": ["ï‰„","ï‰ƒ","ï‰‚","ï‰پ","ï‰€"],
		"tooltip-format": "â‡£ {power:0.1f}W  {capacity}%",
		"tooltip-format-charging": "â‡، {power:0.1f}W  {capacity}%",
		"tooltip-format-plugged": "â‡، {power:0.1f}W  {capacity}%",		"interval": 5,
		"states": {
			"warning": 30,
			"critical": 20
		},
		    "on-click": "omarchy-menu power",
	},
	
    "clock": {
        "format": "{:%I:%M %p}", // AM PM format
        //"format": "{:%H:%M}",// 24H
        "format-alt": "{:%A | %e %B}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "hyprland/language": {
        "format": "  {}",
        "format-en": "US",
        "format-ru": "RU"
    },

