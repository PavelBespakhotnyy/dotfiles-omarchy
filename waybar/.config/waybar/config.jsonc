// THIS CONFIG IS MOSTLY CONFIG FROM VERY COOL GUY atif-1402

{
    "position": "top",
    "margin-top": 12,
    "modules-left": ["clock", "hyprland/language", "mpris"],
    "modules-center": [ "hyprland/workspaces", "custom/notification"],
    "modules-right":[
        "tray",
        "pulseaudio",
        "network",
		"bluetooth",
		"battery",
    ],


    //MODULES//
	"bluetooth": {
		"format": "≤░Γψ  {num_connections}",
		"format-disabled": "≤░Γ▓",
		"format-connected": "≤░Γ▒ {num_connections}",
		"tooltip-format": "{num_connections} connected\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}",
		"on-click": "omarchy-launch-bluetooth"
	},

	// For laptops
	"battery": {
		"format": "{icon}  {capacity}%",
		"format-charging": "{icon}  έΘκ{capacity}%",
		"format-plugged": "{icon}  έΘκ{capacity}%",
		"format-full": "{icon}  100%",
		"format-icons": ["ΎΚΕ","ΎΚΔ","ΎΚΓ","ΎΚΒ","ΎΚΑ"],
		"tooltip-format": "έΘμ {power:0.1f}W  {capacity}%",
		"tooltip-format-charging": "έΘκ {power:0.1f}W  {capacity}%",
		"tooltip-format-plugged": "έΘκ {power:0.1f}W  {capacity}%",		"interval": 5,
		"states": {
			"warning": 30,
			"critical": 20
		},
		    "on-click": "omarchy-menu power",
	},
	
    "clock": {
        "format": "{:%I:%M %p}", // AM PM format
        //"format": "{:%H:%M}",// 24H
        "format-alt": "{:%A | %e %B}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "hyprland/language": {
        "format": "  {}",
        "format-en": "US",
        "format-ru": "RU"
    },

    "hyprland/workspaces": {
	    "persistent-workspaces": {"*": [ 1,2,3,4,5,6 ]},
	    "on-click": "activate",
	    "format": "{windows}",
	    "format-window-separator": " ",
	    "window-rewrite-default": "ΎΒβ",
