    "tray": {
    "icon-size": 21,
    "spacing": 10,
    "icons": {
        "blueman": "bluetooth",
        "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
     }
    },

    "pulseaudio": {
		"format": "{icon}  {volume}",
		"on-click": "omarchy-launch-audio",
		"on-click-right": "omarchy-launch-audio",
		"tooltip-format": "Playing at {volume}%",
		"scroll-step": 5,
		"format-muted": "î»¨  {volume}",
		"format-icons": {
			"default": [
				"ï€¦",
				"ï€§ ",
				"ï€¨ "
			]
		}
    },

    "network": {
		"format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
		"format": "{icon} {essid}",
		"format-wifi": "{icon}  {essid}",
		"format-ethernet": "َ°Œک eth2ernet",
		"format-disconnected": "َ°¤®",
		"tooltip-format-wifi": "{essid} ({frequency} GHz)\nâ‡£{bandwidthDownBytes}  â‡،{bandwidthUpBytes}",
		"tooltip-format-ethernet": "â‡£{bandwidthDownBytes}  â‡،{bandwidthUpBytes}",
		"tooltip-format-disconnected": "Disconnected",
		"interval": 3,
		"spacing": 1,
		"on-click": "omarchy-launch-wifi"
    },

